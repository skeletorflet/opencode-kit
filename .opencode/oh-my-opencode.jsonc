{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "hashline_edit": true,
  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 100
  },
  "disabled_hooks": ["preemptive-compaction"],
  "agents": {
    "sisyphus": {
      "model": "",
      "ultrawork": {
        "model": "",
        "variant": "max"
      }
    },
    "prometheus": {
      "model": "",
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel."
    },
    "atlas": {
      "model": ""
    },
    "oracle": {
      "model": "",
      "variant": "high"
    },
    "hephaestus": {
      "model": ""
    },
    "librarian": { "model": "" },
    "explore":   { "model": "", "temperature": 0.1 }
  },
  "categories": {
    "quick":            { "model": "" },
    "unspecified-low":  { "model": "" },
    "unspecified-high": { "model": "" },
    "deep":             { "model": "" }
  }
}