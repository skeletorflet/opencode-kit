{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5-20251001",
  "instructions": [
    "AGENTS.md",
    ".opencode/rules/RULES.md"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp", "--api-key", "{env:CONTEXT7_API_KEY}"],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "netlify": {
      "type": "local",
      "command": ["npx", "-y", "@netlify/mcp"],
      "enabled": true
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "ask",
    "write": "ask",
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "npm run*": "ask",
      "pnpm *": "ask",
      "node *": "ask",
      "cat *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "ls*": "allow",
      "dir*": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "rm *": "deny",
      "del *": "deny",
      "rmdir *": "deny"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": {
      "*": "allow"
    },
    "task": {
      "*": "allow"
    },
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "agent": {
    "build": {
      "mode": "primary",
      "prompt": "{file:.opencode/prompts/build.txt}",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "npm run*": "ask",
          "pnpm *": "ask",
          "node *": "ask"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "review": {
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow"
        },
        "webfetch": "deny"
      }
    },
    "debugger": {
      "mode": "subagent",
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "cat *": "allow",
          "grep *": "allow",
          "find *": "allow"
        }
      }
    }
  },
  "command": {
    "deploy-check": {
      "description": "Check deployment readiness",
      "template": "Review recent changes and check if the project is ready to deploy.\n!`git diff HEAD~1 --stat`\nList any blockers.",
      "agent": "plan"
    }
  },
  "default_agent": "build"
}