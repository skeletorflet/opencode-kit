{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "anthropic": {
      "apiKey": "env:ANTHROPIC_API_KEY"
    }
  },
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5-20251001",

  "instructions": [
    "AGENTS.md",
    ".opencode/rules/RULES.md",
    ".opencode/rules/GEMINI.md"
  ],

  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "allow",
    "skill": {
      "*": "allow"
    },
    "task": {
      "*": "allow"
    }
  },

  "agent": {
    "build": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "{file:.opencode/prompts/build.txt}",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "npm run*": "ask",
          "pnpm *": "ask",
          "node *": "ask"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-haiku-4-5-20251001",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "review": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow"
        },
        "webfetch": "deny"
      }
    },
    "debugger": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "cat *": "allow",
          "grep *": "allow",
          "find *": "allow"
        }
      }
    }
  },

  "command": {
    "deploy-check": {
      "description": "Check deployment readiness",
      "template": "Review recent changes and check if the project is ready to deploy.\n!`git diff HEAD~1 --stat`\nList any blockers.",
      "agent": "plan"
    }
  },

  "mcp": {
    "context7": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp", "--api-key", "env:CONTEXT7_API_KEY"]
    },
    "shadcn": {
      "type": "local",
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "netlify": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@netlify/mcp"]
    }
  },

  "lsp": {
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"]
    }
  },

  "formatter": {
    "command": "prettier --write $FILE"
  },

  "default_agent": "build"
}
