{
  "$schema": "https://opencode.ai/config.json",
  "model": "",
  "small_model": "",
  "plugin": [
    "./.opencode/plugins/load-env.js",
    // "@daytonaio/opencode",
    "oh-my-openagent"
  ],
  "instructions": [
    "AGENTS.md",
    ".opencode/rules/RULES.md"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "netlify": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@netlify/mcp"
      ],
      "enabled": true
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "allow",
      "*.env.*": "allow",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "write": "allow",
    "bash": {
      "*": "allow",
      "git status": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "npm run*": "allow",
      "pnpm *": "allow",
      "node *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "ls*": "allow",
      "dir*": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "rm *": "allow",
      "del *": "allow",
      "rmdir *": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": {
      "*": "allow"
    },
    "task": {
      "*": "allow"
    },
    "external_directory": "allow",
    "doom_loop": "allow"
  },
  "agent": {
    "build": {
      "mode": "primary",
      "prompt": "{file:.opencode/prompts/build.txt}",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "git status": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "npm run*": "allow",
          "pnpm *": "allow",
          "node *": "allow"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "review": {
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow"
        },
        "webfetch": "allow"
      }
    },
    "debugger": {
      "mode": "subagent",
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "find *": "allow"
        }
      }
    }
  },
  "command": {
    "deploy-check": {
      "description": "Check deployment readiness",
      "template": "Review recent changes and check if the project is ready to deploy.\n!`git diff HEAD~1 --stat`\nList any blockers.",
      "agent": "plan"
    }
  },
  "default_agent": "build"
}