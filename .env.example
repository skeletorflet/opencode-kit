# OpenCode Kit — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your real API keys.
# OpenCode reads these automatically via the shell.env plugin on startup.
#
# WARNING: Never commit `.env` with real keys — it is listed in .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# --- Providers ----------------------------------------------------------------
# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- MCPs --------------------------------------------------------------------
# Context7 (live library docs) — https://upstash.com/
CONTEXT7_API_KEY=

# Daytona (isolated sandboxing) — https://app.daytona.io/
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=

# --- Model overrides ---------------------------------------------------------
# Overrides the model set in opencode.json when set.
# Examples: anthropic/claude-sonnet-4-5 | openai/gpt-4o | google/gemini-pro
# Leave empty to use the value defined in opencode.json
OPENCODE_MODEL=

# Small model (used for lightweight tasks like title generation)
OPENCODE_SMALL_MODEL=
